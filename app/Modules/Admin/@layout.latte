<!DOCTYPE html>
<html lang="cs">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{ifset title}{include title|stripHtml} | {/ifset}Admin – Správa uživatelů</title>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ublaboo-datagrid@latest/assets/datagrid.min.css">
</head>
<body>

	<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
		<div class="container-fluid">
			<a class="navbar-brand" href="{link :Admin:User:default}">
				<i class="bi bi-people-fill me-2"></i>Správa uživatelů
			</a>
			<div class="ms-auto d-flex align-items-center gap-3">
				<span class="text-light small">
					<i class="bi bi-person-circle me-1"></i>{$user->identity?->username ?? 'Uživatel'}
				</span>
				<a class="btn btn-outline-light btn-sm" href="{link :Front:Auth:logout}">
					<i class="bi bi-box-arrow-right me-1"></i>Odhlásit
				</a>
			</div>
		</div>
	</nav>

	<div class="container-fluid mt-4">
		{foreach $flashes as $flash}
			<div class="alert alert-{$flash->type} alert-dismissible fade show" role="alert">
				{$flash->message}
				<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
			</div>
		{/foreach}

		{include content}
	</div>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/nette-forms/src/assets/netteForms.min.js"></script>
</body>
</html>
