<!DOCTYPE html>
<html lang="cs">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{ifset title}{include title|stripHtml} | {/ifset}Správa uživatelů</title>

	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light d-flex flex-column align-items-center justify-content-center vh-100">

	<div class="container px-3" style="max-width: 500px;">
		<div n:foreach="$flashes as $flash" n:class="'alert alert-' . $flash->type, 'mb-3 shadow-sm'">
			{$flash->message}
		</div>
	</div>

	{include content}
	
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
	<script src="https://unpkg.com/nette-forms@3/src/assets/netteForms.js"></script>
</body>
</html>
